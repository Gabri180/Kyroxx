---
const { compact = false } = Astro.props;
---
<div class="logo-wrap" aria-label="Kairoxx">
  <svg viewBox="0 0 168 32" role="img" aria-label="Logo Kairoxx" class:list={[compact && 'compact']}>
    <!-- KX mark -->
    <path d="M8 6v20M8 16L18 6M8 16l10 10" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <path d="M30 6l10 20M40 6L30 26" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <!-- KAIROXX text -->
    <text x="52" y="24" font-family="'Cabinet Grotesk', 'General Sans', sans-serif" font-weight="800" font-size="20" fill="currentColor" letter-spacing="-0.5">KAIROXX</text>
  </svg>
</div>

<style>
  .logo-wrap svg { width: 168px; height: auto; }
  .logo-wrap svg.compact { width: 48px; overflow: visible; }
</style>
